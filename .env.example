# Copy to .env and edit values for your environment
# PostgreSQL
POSTGRES_DB=scheduling_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=0000

# Consul
CONSUL_HOST=consul
CONSUL_PORT=8500

# Kafka
KAFKA_HOST=kafka
KAFKA_PORT=9092

# Spring
SPRING_DATASOURCE_URL=jdbc:postgresql://${POSTGRES_HOST:-postgres}:5432/${POSTGRES_DB}
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}
SPRING_KAFKA_BOOTSTRAP_SERVERS=${KAFKA_HOST}:${KAFKA_PORT}
SPRING_PROFILES_ACTIVE=default

